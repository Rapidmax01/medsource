# ============================================================
# MEDSOURCE BACKEND - Environment Variables
# ============================================================

# App
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRY=30d

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/medsource?schema=public

# Paystack (Primary Payment Provider)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Flutterwave (Fallback Payment Provider)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_WEBHOOK_HASH=your-webhook-hash

# Termii (SMS OTP Provider - Popular in Nigeria)
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=MedSource
TERMII_BASE_URL=https://api.ng.termii.com/api

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=medsource-ng
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@medsource-ng.iam.gserviceaccount.com

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Redis (Optional - for caching & rate limiting)
REDIS_URL=redis://localhost:6379

# NAFDAC Verification (Custom integration)
NAFDAC_API_URL=https://api.nafdac.gov.ng/v1
NAFDAC_API_KEY=your-nafdac-api-key

# Brevo (Email Verification - formerly Sendinblue)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@medsource.ng
BREVO_SENDER_NAME=MedSource
